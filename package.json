{
  "name": "youtube-blue",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "init": "pnpm install && pnpm run build",
    "build:background": "vite build --config config/vite.config.background.ts",
    "build:content": "vite build --config config/vite.config.content.ts",
    "build:popup": "vite build --config config/vite.config.popup.ts",
    "build": "rm -rf dist && pnpm run build:background && pnpm run build:content && pnpm run build:popup",
    "build:firefox": "pnpm run build && web-ext build --source-dir=dist --artifacts-dir=dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "watch-build": "nodemon --watch src --ext ts,tsx,js,jsx,json,html --exec pnpm run build"
  },  
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@uidotdev/usehooks": "^2.4.1",
    "buffer": "^6.0.3",
    "dotenv": "^16.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.79.0",
    "react-i18next": "^15.7.4",
    "vite-bundle-visualizer": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.0.276",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.21",
    "vite-plugin-node-polyfills": "^0.22.0",
    "web-ext": "^8.10.0"
  }
}
